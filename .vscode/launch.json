{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: Dev (F5)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "- Local:\\s+(https?://\\S+)",
        "action": "debugWithEdge",
        "uriFormat": "%s"
      }
    }
  ]
}