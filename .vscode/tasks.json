{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "next: dev",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*next dev.*",
          "endsPattern": "- Local:\\s+https?://\\S+"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": false
      }
    }
  ]
}